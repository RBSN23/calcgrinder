# Calcgrinder — local environment configuration
#
# Copy this file to .env.local and fill in the real values. The .env.local
# file is gitignored. Use the new `sb_publishable_…` / `sb_secret_…` Supabase
# API key format (not the legacy anon / service_role keys).

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me

# ---------------------------------------------------------------------------
# Sysadmin bootstrap — read by `npm run seed:sysadmin`
# SYSADMIN_EMAIL is the login account; SYSADMIN_NOTIFICATION_EMAIL (below)
# is a separate inbox for signup-notification emails.
# ---------------------------------------------------------------------------
SYSADMIN_EMAIL=sysadmin@example.com
SYSADMIN_INITIAL_PASSWORD=replace-with-strong-password-and-change-after-first-login

# ---------------------------------------------------------------------------
# Sysadmin signup-notification recipient (distinct from SYSADMIN_EMAIL)
# ---------------------------------------------------------------------------
SYSADMIN_NOTIFICATION_EMAIL=notifications@example.com

# ---------------------------------------------------------------------------
# Soft-delete retention window (days) — used by the auto-purge cron
# ---------------------------------------------------------------------------
RETENTION_PERIOD_DAYS=30

# ---------------------------------------------------------------------------
# Vercel Cron auth — Vercel auto-sends this as `Authorization: Bearer <CRON_SECRET>`
# when invoking scheduled /api/cron/* endpoints. Any high-entropy random
# string works; rotate by changing the value in the Vercel dashboard.
# ---------------------------------------------------------------------------
CRON_SECRET=replace-with-a-random-string

# ---------------------------------------------------------------------------
# Cyon SMTP — used both by Supabase Auth (configured in the Supabase
# dashboard) and by app-side transactional sends via nodemailer (PROJ-2)
# ---------------------------------------------------------------------------
CYON_SMTP_HOST=smtp.cyon.example
CYON_SMTP_PORT=587
CYON_SMTP_USER=noreply@calcgrinder.example
CYON_SMTP_PASS=replace-with-real-smtp-password
